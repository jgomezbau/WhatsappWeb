{
  "name": "whatsapp-desktop",
  "version": "3.0.0",
  "description": "WhatsApp Desktop para Linux - Cliente moderno no oficial",
  "author": "Juan Bau <jgomezbau@gmail.com>",
  "license": "MIT",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --inspect=5858",
    "build": "electron-builder",
    "build:linux": "electron-builder --linux",
    "build:appimage": "electron-builder --linux AppImage",
    "build:deb": "electron-builder --linux deb",
    "build:all": "electron-builder --linux AppImage deb"
  },
  "build": {
    "appId": "com.whatsapp.desktop.linux",
    "productName": "WhatsApp",
    "copyright": "Copyright © 2025 Juan Bau",
    "directories": {
      "output": "dist",
      "buildResources": "resources"
    },
    "files": [
      "src/**/*",
      "!src/**/*.map"
    ],
    "extraResources": [
      {
        "from": "icons",
        "to": "icons",
        "filter": ["**/*"]
      }
    ],
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64", "arm64"] },
        { "target": "deb", "arch": ["x64"] }
      ],
      "icon": "icons",
      "category": "Network;Chat;InstantMessaging",
      "maintainer": "Juan Bau",
      "executableName": "whatsapp-desktop",
      "synopsis": "Cliente no oficial de WhatsApp con videollamadas para Linux",
      "artifactName": "WhatsApp-Desktop-${version}-${arch}.${ext}",
      "desktop": {
        "entry": {
          "Name": "WhatsApp",
          "Comment": "Cliente no oficial de WhatsApp para Linux",
          "Keywords": "whatsapp;chat;messaging",
          "StartupWMClass": "whatsapp-desktop"
        }
      }
    },
    "deb": {
      "depends": [
        "libnotify4",
        "libxtst6",
        "libnss3",
        "libsecret-1-0",
        "xdg-desktop-portal",
        "xdg-desktop-portal-kde"
      ]
    },
    "protocols": [
      { "name": "WhatsApp", "schemes": ["whatsapp"] }
    ],
    "publish": {
      "provider": "github",
      "owner": "jgomezbau",
      "repo": "whatsapp-desktop-linux"
    }
  },
  "devDependencies": {
    "electron": "^39.8.5",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "electron-updater": "^6.3.0"
  }
}