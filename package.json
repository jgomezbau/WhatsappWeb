{
  "name": "whatsapp-desktop",
  "version": "3.0.0",
  "description": "Unofficial WhatsApp desktop wrapper for Linux built with Electron",
  "author": "Juan Bau <jgomezbau@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/jgomezbau/whatsapp-desktop-linux#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jgomezbau/whatsapp-desktop-linux.git"
  },
  "bugs": {
    "url": "https://github.com/jgomezbau/whatsapp-desktop-linux/issues"
  },
  "keywords": [
    "electron",
    "linux",
    "whatsapp",
    "desktop",
    "appimage",
    "deb"
  ],
  "engines": {
    "node": ">=20"
  },
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --inspect=5858",
    "build": "electron-builder",
    "build:linux": "electron-builder --linux",
    "build:appimage": "electron-builder --linux AppImage",
    "build:deb": "electron-builder --linux deb",
    "build:all": "electron-builder --linux AppImage deb"
  },
  "build": {
    "appId": "com.whatsapp.desktop.linux",
    "productName": "WhatsApp",
    "copyright": "Copyright © 2026 Juan Bau",
    "directories": {
      "output": "dist",
      "buildResources": "resources"
    },
    "files": [
      "src/**/*",
      "!src/**/*.map"
    ],
    "extraResources": [
      {
        "from": "resources/icons",
        "to": "icons",
        "filter": ["**/*"]
      }
    ],
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb", "arch": ["x64"] }
      ],
      "icon": "resources/icons",
      "category": "Network;Chat;InstantMessaging",
      "maintainer": "Juan Bau",
      "executableName": "whatsapp-desktop",
      "synopsis": "Unofficial WhatsApp desktop wrapper for Linux",
      "artifactName": "whatsapp-desktop-linux-${version}-${arch}.${ext}",
      "desktop": {
        "entry": {
          "Name": "WhatsApp",
          "Comment": "Unofficial WhatsApp desktop wrapper for Linux",
          "Keywords": "whatsapp;chat;messaging",
          "StartupWMClass": "whatsapp-desktop"
        }
      }
    },
    "deb": {
      "depends": [
        "libayatana-appindicator3-1 | libappindicator3-1",
        "libnotify4",
        "libxtst6",
        "libnss3",
        "libsecret-1-0",
        "xdg-desktop-portal"
      ]
    },
    "protocols": [
      { "name": "WhatsApp", "schemes": ["whatsapp"] }
    ],
    "publish": {
      "provider": "github",
      "owner": "jgomezbau",
      "repo": "whatsapp-desktop-linux"
    }
  },
  "devDependencies": {
    "electron": "^39.8.5",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "electron-updater": "^6.3.0"
  }
}
